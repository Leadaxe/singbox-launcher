        {
          "name": "dns_server",
          "type": "dns_server",
          "select": "local",
          "title": "DNS server",
          "tooltip": "Recommended: UDP — most stable. DoH/DoT may be filtered by ISPs.",
          "default": "yandex_udp",
          "if": [
            "@use_dns_override"
