  "presets": [
    {
      "id": "private-ips",
      "label": "Private IPs",
      "description": "Route private IP ranges (LAN, etc.) directly to guarantee local network access.",
      "default_enabled": true,
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule": { "ip_is_private": true, "outbound": "@out" }
    },
    {
      "id": "local-lan-domains",
      "label": "Local/LAN domains",
      "description": "Route .local and .lan domains directly for LAN access.",
      "default_enabled": true,
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "lan", "type": "inline", "format": "domain_suffix",
          "rules": [{ "domain_suffix": ["local", "lan"] }] }
      ],
      "rule": { "rule_set": "lan", "outbound": "@out" }
    },
    {
      "id": "block-ads",
      "label": "Block Ads (ads-all, soft)",
      "description": "Soft-block ads by rejecting connections instead of dropping packets.",
      "default_enabled": true,
      "vars": [
        { "name": "out", "type": "outbound", "default": "reject", "title": "Action" }
      ],
      "rule_set": [
        { "tag": "ads", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-ads-all.srs" }
      ],
      "rule": { "rule_set": "ads", "outbound": "@out" }
    },
    {
      "id": "russian",
      "label": "Russian domains & IPs",
      "description": "Route Russian TLDs (.ru/.su/IDN), service CDNs (Yandex/VK/Avito/2GIS/banks/etc) and Russian IP ranges directly.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out",
          "title": "Outbound",
          "tooltip": "Where to route traffic for Russian domains and IPs." },
        { "name": "use_dns_override", "type": "bool", "default": "true",
          "title": "Use Yandex DNS for these domains",
          "tooltip": "Override DNS for matched domains. Disable to resolve via global DNS." },
        { "name": "dns_server", "type": "dns_server", "default": "yandex_udp",
          "if": ["use_dns_override"], "select": "local",
          "title": "DNS server",
          "tooltip": "Recommended: UDP — most stable. DoH/DoT may be filtered by ISPs." },
        { "name": "dns_ip", "type": "enum", "default": "77.88.8.8",
          "if": ["use_dns_override"], "title": "UDP server IP",
          "tooltip": "Applies to UDP only. DoH and DoT are pinned to 77.88.8.88 with SNI safe.dot.dns.yandex.net.",
          "options": [
            { "title": "77.88.8.8 · Base",                     "value": "77.88.8.8" },
            { "title": "77.88.8.1 · Base alt",                 "value": "77.88.8.1" },
            { "title": "2a02:6b8::feed:0ff · Base v6",         "value": "2a02:6b8::feed:0ff" },
            { "title": "77.88.8.88 · Safe",                    "value": "77.88.8.88" },
            { "title": "77.88.8.2 · Safe alt",                 "value": "77.88.8.2" },
            { "title": "2a02:6b8::feed:bad · Safe v6",         "value": "2a02:6b8::feed:bad" },
            { "title": "2a02:6b8:0:1::feed:bad · Safe v6 alt", "value": "2a02:6b8:0:1::feed:bad" },
            { "title": "77.88.8.7 · Family",                   "value": "77.88.8.7" },
            { "title": "77.88.8.3 · Family alt",               "value": "77.88.8.3" },
            { "title": "2a02:6b8::feed:a11 · Family v6",       "value": "2a02:6b8::feed:a11" }
          ]
        },
        { "name": "geoip_enabled", "type": "bool", "default": "true",
          "title": "GeoIP IP-range fallback",
          "tooltip": "Match Russian-AS IPs as well as domains — catches CDN/QUIC/ECH cases where domain detection fails. Requires downloading geoip-ru.srs (~150 KB) via the cloud icon next to the rule." }
      ],
      "rule_set": [
        { "tag": "ru-domains", "type": "inline", "format": "domain_suffix",
          "rules": [{ "domain_suffix": [
            "ru", "su", "xn--p1ai", "xn--p1acf", "xn--80adxhks", "moscow",
            "tatar", "xn--d1acj3b", "xn--80asehdb", "xn--80aswg",
            "xn--c1avg", "xn--j1aef"
          ] }]
        },
        { "tag": "ru-services", "type": "inline", "format": "domain_suffix",
          "rules": [{ "domain_suffix": [
            "userapi.com", "avito.st", "yandex.net", "yandex.com", "yastatic.net",
            "2gis.com", "okko.tv", "premier.one", "lenta.com", "vk.com",
            "vk-portal.net", "gismeteo.com", "lmru.tech", "mradx.net",
            "wbstatic.net", "wildberries.by", "trbcdn.net", "sberbank.com"
          ] }]
        },
        { "tag": "geoip-ru", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru.srs",
          "if": ["geoip_enabled"] }
      ],
      "dns_servers": [
        { "tag": "yandex_udp", "type": "udp",   "server": "@dns_ip",
          "server_port": 53,  "detour": "@out",
          "title":       "Yandex UDP",
          "description": "Yandex public DNS over UDP (port 53). IP from var dns_ip.",
          "if": ["use_dns_override"] },
        { "tag": "yandex_doh", "type": "https", "server": "77.88.8.88",
          "server_port": 443, "path": "/dns-query",
          "tls": { "enabled": true, "server_name": "safe.dot.dns.yandex.net" },
          "detour": "@out",
          "title":       "Yandex DoH",
          "description": "Yandex Safe DoH (77.88.8.88, SNI safe.dot.dns.yandex.net).",
          "if": ["use_dns_override"] },
        { "tag": "yandex_dot", "type": "tls",   "server": "77.88.8.88",
          "server_port": 853,
          "tls": { "enabled": true, "server_name": "safe.dot.dns.yandex.net" },
          "detour": "@out",
          "title":       "Yandex DoT",
          "description": "Yandex Safe DoT (77.88.8.88:853, SNI safe.dot.dns.yandex.net).",
          "if": ["use_dns_override"] }
      ],
      "rule":     { "rule_set": ["ru-domains", "ru-services", "geoip-ru"], "outbound": "@out" },
      "dns_rule": { "rule_set": ["ru-domains", "ru-services"], "server": "@dns_server", "if": ["use_dns_override"] }
    },
    {
      "id": "ru-inside",
      "label": "Russia-only services",
      "description": "Services available only inside Russia — direct (geosite-ru-available-only-inside).",
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "ru-inside", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs" }
      ],
      "rule": { "rule_set": "ru-inside", "outbound": "@out" }
    },
    {
      "id": "ru-blocked",
      "label": "Russian blocked resources",
      "description": "Detour resources blocked in Russia (geoip-ru-blocked + community list) through proxy selector.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "proxy-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "main",      "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked.srs" },
        { "tag": "community", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked-community.srs" }
      ],
      "rule": { "rule_set": ["main", "community"], "network": ["tcp", "udp"], "outbound": "@out" }
    },
    {
      "id": "israel-sites",
      "label": "Israel-specific sites",
      "description": "Send Israel-focused traffic via main proxy selector (geoip-il).",
      "vars": [
        { "name": "out", "type": "outbound", "default": "proxy-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "il", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-il.srs" }
      ],
      "rule": { "rule_set": "il", "outbound": "@out" }
    },
    {
      "id": "bittorrent",
      "label": "BitTorrent",
      "description": "Route BitTorrent traffic directly to avoid VPN throttling.",
      "default_enabled": true,
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule": { "protocol": ["bittorrent"], "outbound": "@out" }
    },
    {
      "id": "ai-services",
      "label": "AI services (Claude, ChatGPT, Perplexity, Gemini)",
      "description": "Route major AI chat services (Anthropic Claude, OpenAI ChatGPT, Perplexity, Google Gemini) through selected outbound. Useful when these services are geo-restricted or require clean IP.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "proxy-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "ai-services", "type": "inline", "format": "domain_suffix",
          "rules": [{ "domain_suffix": [
            "anthropic.com",
            "claude.ai",
            "claudeusercontent.com",
            "openai.com",
            "chatgpt.com",
            "oaistatic.com",
            "oaiusercontent.com",
            "perplexity.ai",
            "pplx.ai",
            "generativelanguage.googleapis.com",
            "gemini.google.com",
            "aistudio.google.com",
            "ai.google.dev",
            "palm.googleapis.com"
          ] }]
        }
      ],
      "rule": { "rule_set": "ai-services", "network": ["tcp", "udp"], "outbound": "@out" }
    },
    {
      "id": "messengers-windows",
      "label": "Messengers",
      "description": "Send messenger traffic (Telegram, WhatsApp, Discord, Signal, Zoom) through proxy. Windows process names.",
      "platforms": ["windows"],
      "vars": [
        { "name": "out", "type": "outbound", "default": "proxy-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "messengers", "type": "inline", "format": "domain_suffix",
          "rules": [
            { "domain_suffix": [
                "meet.google.com", "googlevideo.com", "gstatic.com",
                "googleusercontent.com", "googleapis.com",
                "web.whatsapp.com", "whatsapp.com", "whatsapp.net", "cdn.whatsapp.net", "mmg.whatsapp.net",
                "discord.com", "discordapp.com", "cdn.discordapp.com", "discord.gg", "gateway.discord.gg", "discord.media",
                "telegram.org", "t.me", "cdn-telegram.org"
              ] },
            { "process_name": ["Telegram.exe", "Discord.exe", "WhatsApp.exe", "Signal.exe", "Zoom.exe"] }
          ]
        }
      ],
      "rule": { "rule_set": "messengers", "network": ["tcp", "udp"], "outbound": "@out" }
    },
    {
      "id": "messengers-unix",
      "label": "Messengers",
      "description": "Send messenger traffic (Telegram, WhatsApp, Discord, Signal, Zoom) through proxy. macOS/Linux process names.",
      "platforms": ["darwin", "linux"],
      "vars": [
        { "name": "out", "type": "outbound", "default": "proxy-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "messengers", "type": "inline", "format": "domain_suffix",
          "rules": [
            { "domain_suffix": [
                "meet.google.com", "googlevideo.com", "gstatic.com",
                "googleusercontent.com", "googleapis.com",
                "web.whatsapp.com", "whatsapp.com", "whatsapp.net", "cdn.whatsapp.net", "mmg.whatsapp.net",
                "discord.com", "discordapp.com", "cdn.discordapp.com", "discord.gg", "gateway.discord.gg", "discord.media",
                "telegram.org", "t.me", "cdn-telegram.org"
              ] },
            { "process_name": ["Telegram", "Discord", "WhatsApp", "Signal", "zoom.us"] }
          ]
        }
      ],
      "rule": { "rule_set": "messengers", "network": ["tcp", "udp"], "outbound": "@out" }
    },
    {
      "id": "games",
      "label": "Games",
      "description": "Send gaming rule set traffic directly for lower latency.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule_set": [
        { "tag": "games", "type": "remote", "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-games.srs" }
      ],
      "rule": { "rule_set": "games", "network": ["tcp", "udp"], "outbound": "@out" }
    },
    {
      "id": "gaming-ports",
      "label": "Gaming ports",
      "description": "Keep popular gaming ports and Steam ranges outside VPN.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "direct-out", "title": "Outbound" }
      ],
      "rule": {
        "port": [3659, 1935, 5001, 5795, 5796, 7000, 7777, 9000, 10039, 10040],
        "port_range": "27000:27100",
        "network": ["tcp", "udp"],
        "outbound": "@out"
      }
    },
    {
      "id": "stop-http3",
      "label": "Stop HTTP/3",
      "description": "QUIC does not support UDP traffic proxying — drop HTTP/3 (UDP/443). May reduce speed for Google/YouTube/Cloudflare.",
      "vars": [
        { "name": "out", "type": "outbound", "default": "drop", "title": "Action" }
      ],
      "rule": { "network": ["udp"], "port": [443], "outbound": "@out" }
    },
    {
      "id": "split-all-traffic-mac-win",
      "label": "Split all traffic 50/50 across two outbounds",
      "description": "Distribute proxy-bound traffic across two outbounds by OS source-port (ephemeral range 49152-65535 split in half). Per-connection sticky: one TCP/UDP session stays on one side, one origin (HTTP/2 multiplex) → one outbound. Heavy single-stream traffic (video, large download) does NOT split across both. Enable AFTER all direct/reject presets — this preset acts as catch-all for proxy-bound traffic. macOS / Windows ephemeral range only.",
      "platforms": ["darwin", "windows"],
      "vars": [
        { "name": "out_a", "type": "outbound", "default": "proxy-out", "title": "Outbound A" },
        { "name": "out_b", "type": "outbound", "default": "proxy-out", "title": "Outbound B" }
      ],
      "rule": [
        { "source_port_range": ["49152:57343"], "outbound": "@out_a" },
        { "source_port_range": ["57344:65535"], "outbound": "@out_b" }
      ]
    },
    {
      "id": "split-all-traffic-linux",
      "label": "Split all traffic 50/50 across two outbounds",
      "description": "Distribute proxy-bound traffic across two outbounds by OS source-port (Linux ephemeral range 32768-60999 split in half). Per-connection sticky: one TCP/UDP session stays on one side, one origin (HTTP/2 multiplex) → one outbound. Heavy single-stream traffic (video, large download) does NOT split across both. Enable AFTER all direct/reject presets — this preset acts as catch-all for proxy-bound traffic. Linux ephemeral range only.",
      "platforms": ["linux"],
      "vars": [
        { "name": "out_a", "type": "outbound", "default": "proxy-out", "title": "Outbound A" },
        { "name": "out_b", "type": "outbound", "default": "proxy-out", "title": "Outbound B" }
      ],
      "rule": [
        { "source_port_range": ["32768:46883"], "outbound": "@out_a" },
        { "source_port_range": ["46884:60999"], "outbound": "@out_b" }
      ]
    }
  ],

  "params": [
    {
      "name": "inbounds",
      "platforms": ["windows", "linux"],
      "value": [
        {
          "type": "tun",
          "tag": "tun-in",
          "interface_name": "singbox-tun0",
          "address": ["@tun_address"],
          "mtu": "@tun_mtu",
          "auto_route": true,
          "strict_route": "@strict_route",
          "stack": "@tun_stack"
        }
      ]
    },
    {
      "name": "inbounds",
      "platforms": ["darwin"],
      "if": ["tun"],
      "value": [
        {
          "type": "tun",
          "tag": "tun-in",
          "address": ["@tun_address"],
          "mtu": "@tun_mtu",
          "auto_route": true,
          "strict_route": "@strict_route",
          "stack": "@tun_stack"
        }
      ]
    },
    {
      "name": "inbounds",
      "if": ["enable_proxy_in"],
      "value": [
        {
          "type": "mixed",
          "tag": "proxy-in",
          "listen": "@proxy_in_listen",
          "listen_port": "@proxy_in_listen_port",
          "set_system_proxy": "@proxy_in_set_system_proxy"
        }
      ],
      "mode": "prepend"
    },
    {
      "name": "route.rules",
      "platforms": ["windows", "linux", "darwin"],
      "if_or": ["tun_builtin", "tun"],
      "mode": "prepend",
      "value": [
        { "inbound": "tun-in", "action": "resolve", "strategy": "@resolve_strategy" },
        { "inbound": "tun-in", "action": "sniff", "timeout": "1s" }
      ]
    },
    {
      "name": "route.rules",
      "if": ["enable_proxy_in"],
      "mode": "prepend",
      "value": [
        { "inbound": "proxy-in", "action": "resolve", "strategy": "@resolve_strategy" },
        { "inbound": "proxy-in", "action": "sniff", "timeout": "1s" }
      ]
    }
  ]
}



