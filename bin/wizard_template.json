      "dns_servers": [
        {
          "tag": "yandex_udp",
          "type": "udp",
          "server": "@dns_ip",
          "server_port": 53,
          "detour": "@out",
          "title": "Yandex UDP",
          "description": "Yandex public DNS over UDP (port 53). IP from var dns_ip.",
          "if": [
            "@use_dns_override"
          ]
        },
        {
          "tag": "yandex_doh",
          "type": "https",
          "server": "77.88.8.88",
          "server_port": 443,
          "path": "/dns-query",
          "tls": {
            "enabled": true,
            "server_name": "safe.dot.dns.yandex.net"
          },
          "detour": "@out",
          "title": "Yandex DoH",
          "description": "Yandex Safe DoH (77.88.8.88, SNI safe.dot.dns.yandex.net).",
          "if": [
            "@use_dns_override"
          ]
        },
        {
          "tag": "yandex_dot",
          "type": "tls",
          "server": "77.88.8.88",
          "server_port": 853,
          "tls": {
            "enabled": true,
            "server_name": "safe.dot.dns.yandex.net"
          },
          "detour": "@out",
          "title": "Yandex DoT",
          "description": "Yandex Safe DoT (77.88.8.88:853, SNI safe.dot.dns.yandex.net).",
          "if": [
            "@use_dns_override"
          ]
        }
      ],
      "outbounds": [
        {
          "mode": "update",
          "tag": "proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        },
        {
          "mode": "update",
          "tag": "auto-proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        },
        {
          "tag": "ru VPN 🇷🇺",
          "type": "selector",
          "options": {
            "default": "direct-out",
            "interrupt_exist_connections": true
          },
          "filters": {
            "tag": "/(🇷🇺)/i"
          },
          "addOutbounds": [
            "direct-out"
          ],
          "comment": "RU-only proxy selector (preset.outbounds mode=add; identical body shared with ru-inside when both enabled)"
        }
      ],
      "rules": [
        {
          "rule_set": [
            "ru-domains",
            "ru-services",
            "geoip-ru"
          ],
          "outbound": "@out"
        }
      ],
      "dns_rule": {
        "rule_set": [
          "ru-domains",
          "ru-services"
        ],
        "server": "@dns_server",
        "if": [
          "@use_dns_override"
        ]
      }
    },
    {
      "id": "ru-inside",
      "label": "Russia-only services",
      "description": "Services available only inside Russia — direct (geosite-ru-available-only-inside). Also brings the 'ru VPN 🇷🇺' selector (RU proxies only) and adds an !RU filter to proxy-out/auto-proxy-out so RU traffic goes through ru VPN, not the main proxy.",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "ru VPN 🇷🇺",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "ru-inside",
          "type": "remote",
          "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-ru-available-only-inside.srs"
        }
      ],
      "outbounds": [
        {
          "mode": "update",
          "tag": "proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        },
        {
          "mode": "update",
          "tag": "auto-proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        },
        {
          "tag": "ru VPN 🇷🇺",
          "type": "selector",
          "options": {
            "default": "direct-out",
            "interrupt_exist_connections": true
          },
          "filters": {
            "tag": "/(🇷🇺)/i"
          },
          "addOutbounds": [
            "direct-out"
          ],
          "comment": "RU-only proxy selector (preset.outbounds mode=add, emitted by ru-inside preset)"
        }
      ],
      "rules": [
        {
          "rule_set": "ru-inside",
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "ru-blocked",
      "label": "Russian blocked resources",
      "description": "Detour resources blocked in Russia (geoip-ru-blocked + community list) through proxy selector. Also adds an !RU filter to proxy-out/auto-proxy-out so traffic doesn't accidentally exit through a Russian proxy — that would hit the same blocks you're trying to escape.",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "proxy-out",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "main",
          "type": "remote",
          "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked.srs"
        },
        {
          "tag": "community",
          "type": "remote",
          "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-ru-blocked-community.srs"
        }
      ],
      "outbounds": [
        {
          "mode": "update",
          "tag": "proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        },
        {
          "mode": "update",
          "tag": "auto-proxy-out",
          "filters": {
            "tag": "!/(🇷🇺)/i"
          }
        }
      ],
      "rules": [
        {
          "rule_set": [
            "main",
            "community"
          ],
          "network": [
            "tcp",
            "udp"
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "israel-sites",
      "label": "Israel-specific sites",
      "description": "Send Israel-focused traffic via main proxy selector (geoip-il).",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "proxy-out",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "il",
          "type": "remote",
          "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geoip/geoip-il.srs"
        }
      ],
      "rules": [
        {
          "rule_set": "il",
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "bittorrent",
      "label": "BitTorrent",
      "description": "Route BitTorrent traffic directly to avoid VPN throttling.",
      "default_enabled": true,
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "direct-out",
          "title": "Outbound"
        }
      ],
      "rules": [
        {
          "protocol": [
            "bittorrent"
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "ai-services",
      "label": "AI services (Claude, ChatGPT, Perplexity, Gemini)",
      "description": "Route major AI chat services (Anthropic Claude, OpenAI ChatGPT, Perplexity, Google Gemini) through selected outbound. Useful when these services are geo-restricted or require clean IP.",
      "vars": [
        {
          "name": "out",
