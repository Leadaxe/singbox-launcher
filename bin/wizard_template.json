          "default": "proxy-out",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "ai-services",
          "type": "inline",
          "format": "domain_suffix",
          "rules": [
            {
              "domain_suffix": [
                "anthropic.com",
                "claude.ai",
                "claudeusercontent.com",
                "openai.com",
                "chatgpt.com",
                "oaistatic.com",
