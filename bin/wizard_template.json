{
  "parser_config": {
    "version": 5,
    "proxies": [],
    "outbounds": [
      {
        "tag": "auto-proxy-out",
        "wizard": { "required": 1 },
        "type": "urltest",
        "options": {
          "url": "@urltest_url",
          "interval": "@urltest_interval",
          "tolerance": "@urltest_tolerance",
          "interrupt_exist_connections": true
        },
        "filters": { "tag": "!/(🇷🇺)/i" },
        "comment": "Proxy automated group for everything that should go through VPN"
      },
      {
        "tag": "proxy-out",
        "wizard": { "required": 1 },
        "type": "selector",
        "options": { "interrupt_exist_connections": true, "default": "auto-proxy-out" },
        "filters": { "tag": "!/(🇷🇺)/i" },
        "addOutbounds": ["direct-out", "auto-proxy-out"],
        "comment": "Proxy group for everything that should go through VPN"
      },
      {
        "tag": "ru VPN 🇷🇺",
        "type": "selector",
        "options": {
          "default": "direct-out",
          "interrupt_exist_connections": true
        },
        "filters": { "tag": "/(🇷🇺)/i" },
        "addOutbounds": ["direct-out"],
        "comment": "Proxy group for russian VPN"
      },
      {
        "tag": "vpn ①",
        "type": "selector",
        "options": {
          "default": "proxy-out",
          "interrupt_exist_connections": true
        },
        "addOutbounds": ["direct-out", "proxy-out"],
        "comment": "Proxy group 1"
      },
      {
        "tag": "vpn ②",
        "type": "selector",
        "options": {
          "default": "proxy-out",
          "interrupt_exist_connections": true
        },
        "addOutbounds": ["direct-out", "proxy-out"],
        "comment": "Proxy group 2"
      }
    ],
    "parser": {
      "reload": "12h",
      "last_updated": "2026-04-11T12:00:00Z"
    }
  },

  "vars": [
    {
      "name": "tun",
      "type": "bool",
      "default_value": {"darwin": "true", "default": "false"},
      "wizard_ui": "edit",
      "platforms": ["darwin"],
      "title": "Enable TUN (macOS)",
      "tooltip": "Route traffic through sing-box TUN. Requires administrator privileges on macOS."
    },
    {
      "name": "tun_builtin",
      "type": "bool",
      "default_value": {"windows": "true", "linux": "true", "default": "false"},
      "wizard_ui": "hidden",
      "platforms": ["windows", "linux"],
      "title": "TUN (Windows/Linux)",
      "tooltip": "TUN inbound is always merged on these platforms. Used for template conditions (params.if); not user-editable."
    },
    {
      "name": "tun_address",
      "type": "text",
      "default_value": "172.16.0.1/30",
      "wizard_ui": "edit",
      "if_or": ["tun_builtin", "tun"],
      "title": "TUN interface address",
      "tooltip": "IPv4 CIDR for the TUN interface (inbounds address). Enabled when TUN is on for this platform."
    },
    {
      "name": "tun_mtu",
      "type": "text",
      "default_value": "1492",
      "wizard_ui": "edit",
      "if_or": ["tun_builtin", "tun"],
      "title": "TUN MTU",
      "tooltip": "Maximum transmission unit for the TUN interface (numeric value in JSON)."
    },
    {
      "name": "strict_route",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "edit",
      "if_or": ["tun_builtin", "tun"],
      "title": "TUN strict route",
      "tooltip": "sing-box tun strict_route: stricter routing (fewer leaks); may break some LAN or split setups when enabled."
    },
    {
      "name": "tun_stack",
      "type": "enum",
      "default_value": {"win7": "gvisor", "default": "system"},
      "options": ["system", "gvisor", "mixed"],
      "wizard_ui": "edit",
      "if_or": ["tun_builtin", "tun"],
      "title": "TUN stack",
      "tooltip": "sing-box inbound tun stack (system, gvisor, mixed). Mixed uses system TCP stack and gvisor UDP stack."
    },
    {"separator": true},
    {
      "name": "enable_proxy_in",
      "type": "bool",
      "default_value": {"darwin": "true", "default": "false"},
      "wizard_ui": "edit",
      "title": "Enable proxy-in",
      "tooltip": "Adds mixed inbound proxy-in and route.rules for proxy-in. Can be enabled on any platform for experiments."
    },
    {
      "name": "proxy_in_listen",
      "type": "text",
      "default_value": "127.0.0.1",
      "wizard_ui": "edit",
      "if": ["enable_proxy_in"],
      "title": "Proxy-in listen address",
      "tooltip": "Listen address for mixed inbound proxy-in."
    },
    {
      "name": "proxy_in_listen_port",
      "type": "text",
      "default_value": "7890",
      "wizard_ui": "edit",
      "if": ["enable_proxy_in"],
      "title": "Proxy-in listen port",
      "tooltip": "Listen port for mixed inbound proxy-in."
    },
    {
      "name": "proxy_in_set_system_proxy",
      "type": "bool",
      "default_value": {"darwin": "true", "default": "false"},
      "wizard_ui": "edit",
      "if": ["enable_proxy_in"],
      "title": "Proxy-in set system proxy",
      "tooltip": "Set system proxy through mixed inbound proxy-in. Some platforms require elevated privileges."
    },
    {"separator": true},
    {
      "name": "resolve_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "edit",
      "title": "Route resolve strategy",
      "tooltip": "Resolution strategy for route rules with action resolve on tun-in and proxy-in (sing-box: prefer_ipv4, prefer_ipv6, ipv4_only, ipv6_only)."
    },
    {
      "name": "auto_detect_interface",
      "type": "bool",
      "default_value": "true",
      "wizard_ui": "edit",
      "title": "Auto-detect outbound interface",
      "tooltip": "sing-box route.auto_detect_interface: detect default interface for outbound; turn off if routing is wrong with multiple uplinks."
    },
    {
      "name": "cert_store",
      "type": "enum",
      "default_value": "system",
      "options": [
        { "title": "System (default — OS trust store)", "value": "system" },
        { "title": "Mozilla CA bundle (built-in)", "value": "mozilla" },
        { "title": "Chrome Root Store (built-in)", "value": "chrome" }
      ],
      "wizard_ui": "edit",
      "title": "TLS root certificate store",
      "tooltip": "sing-box certificate.store — which CA bundle to trust for outbound TLS validation. 'system' uses your OS cert store. 'mozilla' / 'chrome' use built-in bundles, useful when the OS store is broken (e.g. Windows updates not applied, or x509 'unknown authority' errors). 'none' disables CA validation entirely — only for testing. https://sing-box.sagernet.org/configuration/certificate/"
    },
    {"separator": true},
    {
      "name": "urltest_url",
      "type": "text",
      "default_value": "https://cp.cloudflare.com/generate_204",
      "options": [
        "https://cp.cloudflare.com/generate_204",
        "http://www.gstatic.com/generate_204",
        "https://www.google.com/generate_204",
        "http://connectivitycheck.gstatic.com/generate_204"
      ],
      "wizard_ui": "edit",
      "title": "URLTest URL",
      "tooltip": "sing-box urltest.url — endpoint to probe for latency when selecting the fastest node in auto-proxy-out. Pick a preset or type any HTTP(S) URL that returns a quick response."
    },
    {
      "name": "urltest_interval",
      "type": "enum",
      "default_value": "5m",
      "options": [
        {"title": "1m (aggressive)",      "value": "1m"},
        {"title": "5m (default)",         "value": "5m"},
        {"title": "10m",                  "value": "10m"},
        {"title": "30m (battery-sparing)","value": "30m"},
        {"title": "1h",                   "value": "1h"}
      ],
      "wizard_ui": "edit",
      "title": "URLTest interval",
      "tooltip": "sing-box urltest.interval — how often to re-probe all nodes in auto-proxy-out. Pick a preset."
    },
    {
      "name": "urltest_tolerance",
      "type": "enum",
      "default_value": "100",
      "options": [
        {"title": "50 ms (twitchy)",     "value": "50"},
        {"title": "100 ms (default)",    "value": "100"},
        {"title": "200 ms",              "value": "200"},
        {"title": "500 ms (stable)",     "value": "500"}
      ],
      "wizard_ui": "edit",
      "title": "URLTest tolerance (ms)",
      "tooltip": "sing-box urltest.tolerance — don't switch node unless the new fastest one beats the current by this many milliseconds. Higher = less flap."
    },
    {"separator": true},
    {
      "name": "log_level",
      "type": "enum",
      "default_value": "warn",
      "options": ["trace", "debug", "info", "warn", "error", "fatal", "panic"],
      "wizard_ui": "edit",
      "title": "Log level",
      "tooltip": "Sing-box log.level (trace, debug, info, warn, error, fatal, panic)."
    },
    {"separator": true},
    {
      "name": "clash_api",
      "type": "text",
      "default_value": "127.0.0.1:9090",
      "wizard_ui": "edit",
      "title": "Clash API address",
      "tooltip": "Host:port for external_controller (Clash-compatible REST API)."
    },
    {
      "name": "clash_secret",
      "type": "secret",
      "default_value": "CHANGE_THIS_TO_YOUR_SECRET_TOKEN",
      "wizard_ui": "edit",
      "title": "Clash API secret",
      "tooltip": "Secret for the Clash API. Use the refresh button to generate a random value."
    },
    {
      "name": "dns_strategy",
      "type": "enum",
      "default_value": "prefer_ipv4",
      "options": ["prefer_ipv4", "prefer_ipv6", "ipv4_only", "ipv6_only"],
      "wizard_ui": "fix",
      "title": "Strategy",
      "comment": "DNS tab only: sing-box config.dns.strategy.",
      "tooltip":"sing-box config.dns.strategy."
    },
    {
      "name": "dns_independent_cache",
      "type": "bool",
      "default_value": "false",
      "wizard_ui": "fix",
      "title": "Independent cache",
      "tooltip": "sing-box config.dns.independent_cache.",
      "comment": "DNS tab only: config.dns.independent_cache; same bool+fix pattern for dedicated DNS-tab editing (not shown on Settings)."
    },
    {
      "name": "dns_default_domain_resolver",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "Default DNS domain resolver",
      "tooltip": "sing-box config.route.default_domain_resolver (server tag).",
      "comment": "DNS tab only: route.default_domain_resolver (server tag)."
    },
    {
      "name": "dns_final",
      "type": "text",
      "default_value": "direct_dns_resolver",
      "wizard_ui": "fix",
      "title": "Final",
      "tooltip": "sing-box config.dns.final (server tag).",
      "comment": "DNS tab only: config.dns.final (server tag)."
    },
    {
      "name": "route_final",
      "type": "text",
      "default_value": "proxy-out",
      "wizard_ui": "hidden",
      "title": "Final outbound",
      "tooltip": "sing-box config.route.final — the outbound used for any traffic that didn't match any rule. Edited via Configurator → Rules tab → 'Final outbound' dropdown (UI surface lives there because the available choices depend on the current outbound list, which is dynamic)."
    }
  ],

  "config": {
    "log": {
      "level": "@log_level",
      "timestamp": true
    },
    "certificate": {
      "store": "@cert_store"
    },
    "dns": {
      "servers": [
        {
          "type": "local",
          "tag": "local_dns_resolver"
        },
        {
          "type": "udp",
          "tag": "direct_dns_resolver",
          "server": "8.8.8.8",
          "server_port": 53
        }
      ],
      "rules": [
      ],
      "final": "@dns_final",
      "strategy": "@dns_strategy",
      "independent_cache": "@dns_independent_cache"
    },
    "inbounds": [],
    "endpoints": [],
    "outbounds": [
      { "type": "direct", "tag": "direct-out" }
    ],
    "route": {
      "default_domain_resolver": "@dns_default_domain_resolver",
      "rules": [
        { "protocol": "dns", "action": "hijack-dns" }
      ],
      "final": "@route_final",
      "auto_detect_interface": "@auto_detect_interface"
    },
    "experimental": {
      "clash_api": {
        "external_controller": "@clash_api",
        "secret": "@clash_secret"
      },
      "cache_file": {
        "enabled": true,
        "path": "cache.db"
      }
    }
  },

