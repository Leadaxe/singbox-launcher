                    "WhatsApp",
                    "Signal",
                    "zoom.us"
                  ]
                }
              }
            }
          ]
        }
      ],
      "rules": [
        {
          "rule_set": "messengers",
          "network": [
            "tcp",
            "udp"
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "games",
      "label": "Games",
      "description": "Send gaming rule set traffic directly for lower latency.",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "direct-out",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "games",
          "type": "remote",
          "format": "binary",
          "url": "https://raw.githubusercontent.com/runetfreedom/russia-v2ray-rules-dat/release/sing-box/rule-set-geosite/geosite-category-games.srs"
        }
      ],
      "rules": [
        {
          "rule_set": "games",
          "network": [
            "tcp",
            "udp"
          ],
