    {
      "id": "gaming-ports",
      "label": "Gaming ports",
      "description": "Keep popular gaming ports and Steam ranges outside VPN.",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "direct-out",
          "title": "Outbound"
        }
      ],
      "rules": [
        {
          "port": [
            3659,
            1935,
            5001,
            5795,
            5796,
            7000,
            7777,
            9000,
            10039,
            10040
          ],
          "port_range": "27000:27100",
          "network": [
            "tcp",
            "udp"
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "stop-http3",
      "label": "Stop HTTP/3",
      "description": "QUIC does not support UDP traffic proxying — drop HTTP/3 (UDP/443). May reduce speed for Google/YouTube/Cloudflare.",
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "drop",
          "title": "Action"
        }
      ],
      "rules": [
        {
          "network": [
            "udp"
          ],
          "port": [
            443
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "fakeip",
      "label": "FakeIP (faster connect)",
      "description": "Answer proxied A/AAAA lookups from a synthetic pool instead of resolving upstream — the real domain is recovered by sniffing, so connections open faster and DNS leaks less. Keep this preset AFTER Russian/direct rules so local domains still resolve for real.",
      "vars": [
        {
          "name": "dns_server",
          "type": "dns_server",
          "select": "local",
          "title": "FakeIP server",
          "default": "fakeip",
          "tooltip": "DNS server that returns synthetic IPs. Leave as the bundled fakeip server."
        },
        {
          "name": "inet4_range",
          "type": "text",
          "default": "198.18.0.0/15",
          "title": "IPv4 fake range",
          "tooltip": "CIDR pool for synthetic IPv4 answers (sing-box dns fakeip inet4_range)."
        },
        {
          "name": "inet6_range",
          "type": "text",
          "default": "fc00::/18",
          "title": "IPv6 fake range",
          "tooltip": "CIDR pool for synthetic IPv6 answers (sing-box dns fakeip inet6_range)."
        },
        {
          "name": "force",
          "type": "bool",
          "title": "Block HTTPS/SVCB records",
          "default": "true",
          "tooltip": "Answer HTTPS/SVCB (HTTP/3 & ECH hint) queries as empty so browsers fall back to A/AAAA and cannot bypass FakeIP via an ipv4hint. Recommended on."
        }
      ],
      "dns_servers": [
        {
          "tag": "fakeip",
          "type": "fakeip",
          "inet4_range": "@inet4_range",
          "inet6_range": "@inet6_range",
          "title": "FakeIP",
          "description": "Synthetic-IP DNS server (sing-box type fakeip)."
        }
      ],
      "dns_rules": [
        {
          "query_type": [
            "HTTPS",
            "SVCB"
          ],
          "action": "predefined",
          "rcode": "NOERROR",
          "if": [
            "@force"
          ]
        },
        {
          "query_type": [
            "A",
            "AAAA"
          ],
          "server": "@dns_server"
        }
      ],
      "default_enabled": true
    },
    {
      "id": "split-all-traffic",
      "label": "Split all traffic 50/50 across two outbounds",
      "description": "Distribute proxy-bound traffic across two outbounds by OS source-port (ephemeral range split in half). Per-connection sticky: one TCP/UDP session stays on one side, one origin (HTTP/2 multiplex) → one outbound. Heavy single-stream traffic (video, large download) does NOT split across both. Enable AFTER all direct/reject presets — this preset acts as catch-all for proxy-bound traffic. Ephemeral range: macOS/Windows 49152-65535, Linux 32768-60999.",
      "vars": [
        {
          "name": "out_a",
          "type": "outbound",
          "default": "proxy-out",
          "title": "Outbound A"
        },
        {
          "name": "out_b",
          "type": "outbound",
          "default": "proxy-out",
          "title": "Outbound B"
        }
      ],
      "rules": [
        {
          "source_port_range": [
            {
              "#if": {
                "and": [
                  {
                    "@runtime.platform": "linux"
                  }
                ],
                "value": "32768:46883",
                "else": "49152:57343"
              }
            }
          ],
          "outbound": "@out_a"
        },
        {
          "source_port_range": [
            {
              "#if": {
                "and": [
                  {
                    "@runtime.platform": "linux"
                  }
                ],
                "value": "46884:60999",
                "else": "57344:65535"
              }
            }
          ],
          "outbound": "@out_b"
        }
      ]
    }
  ],
  "params": [
    {
      "name": "inbounds",
      "if": [
        "@tun"
      ],
      "value": [
        {
          "type": "tun",
          "tag": "tun-in",
          "auto_route": true,
          "address": [
            "@tun_address"
          ],
          "mtu": "@tun_mtu",
          "strict_route": "@strict_route",
          "stack": "@tun_stack",
          "#if": {
            "and": [
              {
                "@runtime.platform": {
                  "#in": [
                    "windows",
                    "linux"
                  ]
                }
              }
            ],
            "value": {
              "interface_name": "singbox-tun0"
            }
          }
        }
      ]
    },
    {
      "name": "inbounds",
      "if": [
        "@enable_proxy_in"
      ],
      "value": [
        {
          "type": "mixed",
          "tag": "proxy-in",
          "listen": "@proxy_in_listen",
          "listen_port": "@proxy_in_listen_port",
          "set_system_proxy": "@proxy_in_set_system_proxy",
          "#if": {
            "and": [
              "@proxy_in_auth_enabled",
              {
                "@proxy_in_username": "#notEmpty"
              }
            ],
            "value": {
              "users": [
                {
                  "username": "@proxy_in_username",
                  "password": "@proxy_in_password"
                }
              ]
            }
          }
        }
      ],
      "mode": "prepend"
    },
    {
      "name": "route.rules",
      "if_or": [
        "@tun",
        "@enable_proxy_in"
      ],
      "mode": "prepend",
      "value": [
        {
          "inbound": [
            {
              "#if": {
                "and": [
                  "@tun"
                ],
                "value": "tun-in"
              }
            },
            {
              "#if": {
                "and": [
                  "@enable_proxy_in"
                ],
                "value": "proxy-in"
              }
            }
          ],
          "action": "resolve",
          "strategy": "@resolve_strategy"
        },
        {
          "inbound": [
            {
              "#if": {
                "and": [
                  "@tun"
                ],
                "value": "tun-in"
              }
            },
            {
              "#if": {
                "and": [
                  "@enable_proxy_in"
                ],
                "value": "proxy-in"
              }
            }
          ],
          "action": "sniff",
          "timeout": "1s"
        }
      ]
    }
  ]
}
