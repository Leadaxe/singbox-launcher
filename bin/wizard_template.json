{
  "parser_config": {
    "version": 5,
    "proxies": [],
    "outbounds": [
      {
        "tag": "auto-proxy-out",
        "type": "urltest",
        "options": {
          "url": "@urltest_url",
          "interval": "@urltest_interval",
          "tolerance": "@urltest_tolerance",
          "interrupt_exist_connections": true
        },
        "comment": "Proxy automated group for everything that should go through VPN."
      },
      {
        "required": true,
        "tag": "proxy-out",
        "type": "selector",
        "options": {
          "interrupt_exist_connections": true,
          "default": "auto-proxy-out"
        },
        "addOutbounds": [
          "direct-out",
          "auto-proxy-out"
        ],
        "comment": "Proxy group for everything that should go through VPN."
      },
      {
        "tag": "vpn ①",
        "type": "selector",
        "options": {
          "default": "proxy-out",
          "interrupt_exist_connections": true
        },
        "addOutbounds": [
          "direct-out",
          "proxy-out"
        ],
        "comment": "Proxy group 1"
      },
      {
        "tag": "vpn ②",
        "type": "selector",
        "options": {
          "default": "proxy-out",
          "interrupt_exist_connections": true
        },
        "addOutbounds": [
          "direct-out",
          "proxy-out"
        ],
        "comment": "Proxy group 2"
      }
    ],
    "parser": {
      "reload": "12h",
      "last_updated": "2026-04-11T12:00:00Z"
    }
  },
  "vars": [
    {
      "name": "tun",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Enable TUN",
      "tooltip": "Route traffic through sing-box TUN inbound. Requires administrator privileges. If you disable TUN, enable Proxy-in below and point your browser/system to that proxy — otherwise no traffic will flow through sing-box.",
      "default_value": {
        "windows": "true",
        "linux": "true",
        "darwin": "true",
        "default": "false"
      }
    },
    {
      "name": "tun_address",
      "type": "text",
      "wizard_ui": "edit",
      "title": "TUN interface address",
      "tooltip": "IPv4 CIDR for the TUN interface (inbounds address). Enabled when TUN is on for this platform.",
      "default_value": "172.16.0.1/30",
      "if": [
        "@tun"
      ]
    },
    {
      "name": "tun_mtu",
      "type": "text",
      "wizard_ui": "edit",
      "title": "TUN MTU",
      "tooltip": "Maximum transmission unit for the TUN interface (numeric value in JSON).",
      "default_value": "1492",
      "if": [
        "@tun"
      ]
    },
    {
      "name": "strict_route",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "TUN strict route",
      "tooltip": "sing-box tun strict_route: stricter routing (fewer leaks); may break some LAN or split setups when enabled.",
      "default_value": "false",
      "if": [
        "@tun"
      ]
    },
    {
      "name": "tun_stack",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "TUN stack",
      "tooltip": "sing-box inbound tun stack (system, gvisor, mixed). Mixed uses system TCP stack and gvisor UDP stack.",
      "default_value": {
        "default": {
          "#if": {
            "and": [
              {
                "@runtime.platform": "windows"
              },
              {
                "@runtime.arch": "386"
              }
            ],
            "value": "gvisor",
            "else": "system"
          }
        }
      },
      "options": [
        "system",
        "gvisor",
        "mixed"
      ],
      "if": [
        "@tun"
      ]
    },
    {
      "separator": true
    },
    {
      "name": "enable_proxy_in",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Enable proxy-in",
      "tooltip": "Adds mixed inbound proxy-in and route.rules for proxy-in. Can be enabled on any platform for experiments.",
      "default_value": {
        "darwin": "true",
        "default": "false"
      }
    },
    {
      "name": "proxy_in_listen",
      "type": "text",
      "wizard_ui": "edit",
      "title": "Proxy-in listen address",
      "tooltip": "Listen address for mixed inbound proxy-in.",
      "default_value": "127.0.0.1",
      "if": [
        "@enable_proxy_in"
      ]
    },
    {
      "name": "proxy_in_listen_port",
      "type": "text",
      "wizard_ui": "edit",
      "title": "Proxy-in listen port",
      "tooltip": "Listen port for mixed inbound proxy-in.",
      "default_value": "7890",
      "if": [
        "@enable_proxy_in"
      ]
    },
    {
      "name": "proxy_in_set_system_proxy",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Proxy-in set system proxy",
      "tooltip": "Set system proxy through mixed inbound proxy-in. Some platforms require elevated privileges.",
      "default_value": {
        "darwin": "true",
        "default": "false"
      },
      "if": [
        "@enable_proxy_in"
      ]
    },
    {
      "name": "proxy_in_auth_enabled",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Proxy-in require authentication",
      "tooltip": "When enabled, clients connecting to mixed inbound proxy-in must provide a username and password.",
      "default_value": "false",
      "if": [
        "@enable_proxy_in"
      ]
    },
    {
      "name": "proxy_in_username",
      "type": "text",
      "wizard_ui": "edit",
      "title": "Proxy-in username",
      "tooltip": "Username for mixed inbound proxy-in authentication.",
      "default_value": "",
      "if": [
        "@enable_proxy_in",
        "@proxy_in_auth_enabled"
      ]
    },
    {
      "name": "proxy_in_password",
      "type": "secret",
      "wizard_ui": "edit",
      "title": "Proxy-in password",
      "tooltip": "Password for mixed inbound proxy-in authentication.",
      "default_value": "",
      "if": [
        "@enable_proxy_in",
        "@proxy_in_auth_enabled"
      ]
    },
    {
      "separator": true
    },
    {
      "name": "resolve_strategy",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "Route resolve strategy",
      "tooltip": "Resolution strategy for route rules with action resolve on tun-in and proxy-in (sing-box: prefer_ipv4, prefer_ipv6, ipv4_only, ipv6_only).",
      "default_value": "prefer_ipv4",
      "options": [
        "prefer_ipv4",
        "prefer_ipv6",
        "ipv4_only",
        "ipv6_only"
      ]
    },
    {
      "name": "auto_detect_interface",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Auto-detect outbound interface",
      "tooltip": "sing-box route.auto_detect_interface: detect default interface for outbound; turn off if routing is wrong with multiple uplinks.",
      "default_value": "true"
    },
    {
      "name": "cert_store",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "TLS root certificate store",
      "tooltip": "sing-box certificate.store — which CA bundle to trust for outbound TLS validation. 'system' uses your OS cert store. 'mozilla' / 'chrome' use built-in bundles, useful when the OS store is broken (e.g. Windows updates not applied, or x509 'unknown authority' errors). 'none' disables CA validation entirely — only for testing. https://sing-box.sagernet.org/configuration/certificate/",
      "default_value": "system",
      "options": [
        {
          "title": "System (default — OS trust store)",
          "value": "system"
        },
        {
          "title": "Mozilla CA bundle (built-in)",
          "value": "mozilla"
        },
        {
          "title": "Chrome Root Store (built-in)",
          "value": "chrome"
        }
      ]
    },
    {
      "separator": true
    },
    {
      "name": "tls_fragment",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "TLS fragment (anti-DPI)",
      "tooltip": "Split the TLS ClientHello across packets so a DPI cannot match the SNI in one read. Applied to first-hop TLS proxy outbounds. Helps against RU/TSPU SNI blocking. sing-box tls.fragment.",
      "default_value": "false"
    },
    {
      "name": "tls_record_fragment",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "TLS record fragment",
      "tooltip": "Split every TLS record, not just the ClientHello (stronger, slightly slower). sing-box tls.record_fragment. Use with TLS fragment.",
      "default_value": "false",
      "if": [
        "@tls_fragment"
      ]
    },
    {
      "name": "tls_fragment_fallback_delay",
      "type": "text",
      "wizard_ui": "edit",
      "title": "Fragment fallback delay",
      "tooltip": "sing-box tls.fragment_fallback_delay — delay before falling back if fragmentation stalls (e.g. 500ms). Leave empty for the core default.",
      "default_value": "",
      "if": [
        "@tls_fragment"
      ]
    },
    {
      "name": "tls_mixed_case_sni",
      "type": "bool",
      "wizard_ui": "edit",
      "title": "Mixed-case SNI",
      "tooltip": "Randomize the letter case of the SNI hostname. TLS SNI is case-insensitive (RFC 6066) so servers accept it, but a case-sensitive DPI blocklist match is defeated. Punycode labels are left intact.",
      "default_value": "false"
    },
    {
      "separator": true
    },
    {
      "name": "urltest_url",
      "type": "text",
      "wizard_ui": "edit",
      "title": "URLTest URL",
      "tooltip": "sing-box urltest.url — endpoint to probe for latency when selecting the fastest node in auto-proxy-out. Pick a preset or type any HTTP(S) URL that returns a quick response.",
      "default_value": "https://cp.cloudflare.com/generate_204",
      "options": [
        "https://cp.cloudflare.com/generate_204",
        "http://www.gstatic.com/generate_204",
        "https://www.google.com/generate_204",
        "http://connectivitycheck.gstatic.com/generate_204"
      ]
    },
    {
      "name": "urltest_interval",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "URLTest interval",
      "tooltip": "sing-box urltest.interval — how often to re-probe all nodes in auto-proxy-out. Pick a preset.",
      "default_value": "5m",
      "options": [
        {
          "title": "1m (aggressive)",
          "value": "1m"
        },
        {
          "title": "5m (default)",
          "value": "5m"
        },
        {
          "title": "10m",
          "value": "10m"
        },
        {
          "title": "30m (battery-sparing)",
          "value": "30m"
        },
        {
          "title": "1h",
          "value": "1h"
        }
      ]
    },
    {
      "name": "urltest_tolerance",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "URLTest tolerance (ms)",
      "tooltip": "sing-box urltest.tolerance — don't switch node unless the new fastest one beats the current by this many milliseconds. Higher = less flap.",
      "default_value": "100",
      "options": [
        {
          "title": "50 ms (twitchy)",
          "value": "50"
        },
        {
          "title": "100 ms (default)",
          "value": "100"
        },
        {
          "title": "200 ms",
          "value": "200"
        },
        {
          "title": "500 ms (stable)",
          "value": "500"
        }
      ]
    },
    {
      "separator": true
    },
    {
      "name": "log_level",
      "type": "enum",
      "wizard_ui": "edit",
      "title": "Log level",
      "tooltip": "Sing-box log.level (trace, debug, info, warn, error, fatal, panic).",
      "default_value": "warn",
      "options": [
        "trace",
        "debug",
        "info",
        "warn",
        "error",
        "fatal",
        "panic"
      ]
    },
    {
      "separator": true
    },
    {
      "name": "clash_api",
      "type": "text",
      "wizard_ui": "edit",
      "title": "Clash API address",
      "tooltip": "Host:port for external_controller (Clash-compatible REST API).",
      "default_value": "127.0.0.1:9090"
    },
    {
      "name": "clash_secret",
      "type": "secret",
      "wizard_ui": "edit",
      "title": "Clash API secret",
      "tooltip": "Secret for the Clash API. Use the refresh button to generate a random value.",
      "default_value": "CHANGE_THIS_TO_YOUR_SECRET_TOKEN"
    },
    {
      "name": "dns_strategy",
      "type": "enum",
      "wizard_ui": "fix",
      "title": "Strategy",
      "comment": "DNS tab only: sing-box config.dns.strategy.",
      "tooltip": "sing-box config.dns.strategy.",
      "default_value": "prefer_ipv4",
      "options": [
        "prefer_ipv4",
        "prefer_ipv6",
        "ipv4_only",
        "ipv6_only"
      ]
    },
    {
      "name": "dns_default_domain_resolver",
      "type": "text",
      "wizard_ui": "fix",
      "title": "Default DNS domain resolver",
      "tooltip": "sing-box config.route.default_domain_resolver (server tag).",
      "comment": "DNS tab only: route.default_domain_resolver (server tag).",
      "default_value": "direct_dns_resolver"
    },
    {
      "name": "dns_final",
      "type": "text",
      "wizard_ui": "fix",
      "title": "Final",
      "tooltip": "sing-box config.dns.final (server tag).",
      "comment": "DNS tab only: config.dns.final (server tag).",
      "default_value": "direct_dns_resolver"
    },
    {
      "name": "route_final",
      "type": "text",
      "wizard_ui": "hidden",
      "title": "Final outbound",
      "tooltip": "sing-box config.route.final — the outbound used for any traffic that didn't match any rule. Edited via Configurator → Rules tab → 'Final outbound' dropdown (UI surface lives there because the available choices depend on the current outbound list, which is dynamic).",
      "default_value": "proxy-out"
    }
  ],
  "config": {
    "log": {
      "level": "@log_level",
      "timestamp": true
    },
    "certificate": {
      "store": "@cert_store"
    },
    "dns": {
      "servers": [],
      "rules": [],
      "final": "@dns_final",
      "strategy": "@dns_strategy"
    },
    "inbounds": [],
    "endpoints": [],
    "outbounds": [
      {
        "type": "direct",
        "tag": "direct-out"
      },
      {
        "type": "block",
        "tag": "block-out"
      }
    ],
    "route": {
      "default_domain_resolver": "@dns_default_domain_resolver",
      "rules": [
        {
          "protocol": "dns",
          "action": "hijack-dns"
        }
      ],
      "final": "@route_final",
      "auto_detect_interface": "@auto_detect_interface",
      "find_process": true
    },
    "experimental": {
      "clash_api": {
        "external_controller": "@clash_api",
        "secret": "@clash_secret"
      },
      "cache_file": {
        "enabled": true,
        "path": "cache.db",
        "store_fakeip": true
      }
    }
  },
  "dns_options": {
    "servers": [
      {
        "type": "local",
        "tag": "local_dns_resolver",
        "description": "OS system resolver",
