        "server_port": 443,
        "path": "/dns-query",
        "domain_resolver": "direct_dns_resolver",
        "detour": "proxy-out",
        "description": "Google DNS over HTTPS resolver",
        "enabled": false
      }
    ]
  },
  "presets": [
    {
      "id": "private-ips",
      "label": "Private IPs",
      "description": "Route private IP ranges (LAN, etc.) directly to guarantee local network access.",
      "default_enabled": true,
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "direct-out",
          "title": "Outbound"
        }
      ],
      "rules": [
        {
          "ip_is_private": true,
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "local-lan-domains",
