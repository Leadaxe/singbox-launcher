                "palm.googleapis.com"
              ]
            }
          ]
        }
      ],
      "rules": [
        {
          "rule_set": "ai-services",
          "network": [
            "tcp",
            "udp"
          ],
          "outbound": "@out"
        }
      ]
    },
    {
      "id": "messengers",
      "label": "Messengers",
      "description": "Send messenger traffic (Telegram, WhatsApp, Discord, Signal, Zoom) through proxy. Process names adapt per OS automatically.",
      "platforms": [
        "windows",
        "darwin",
        "linux"
      ],
      "vars": [
        {
          "name": "out",
          "type": "outbound",
          "default": "proxy-out",
          "title": "Outbound"
        }
      ],
      "rule_set": [
        {
          "tag": "messengers",
          "type": "inline",
          "format": "domain_suffix",
          "rules": [
            {
              "domain_suffix": [
                "meet.google.com",
                "googlevideo.com",
                "gstatic.com",
